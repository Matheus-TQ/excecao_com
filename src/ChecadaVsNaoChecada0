public class ChecadaVsNaoChecada01 {

	public static void main(String[] args) {
		try {
			generateErro1();
		} catch (RuntimeException e) {
			System.out.println(e.getMessage());
		}
		try {
			generateErro2();
		} catch (Throwable e) {
			System.out.println(e.getMessage());
		}
		
		System.out.println("Fim :)");
	}
	
	// Exceção NÃO checada ou NÃO verificada
	static void generateErro1() {
		throw new RuntimeException("A really cool mistake occurred #01");
	}
	// Exceção checada ou verificada, voce pode resolver dentro do proprio metodo usando o try catch
	static void generateErro2() throws Exception{
		throw new Exception("Ocorreu um erro bem legal #02");
	}
}
